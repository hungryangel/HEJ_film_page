---
/**
 * Footer — 필름 엣지 마크 + 브랜드 + 카피라이트
 */
import { site } from '../data/site';
---

<footer class="w-full" style="background:#EDE8DF; border-top:1px solid rgba(196,168,130,0.25);">
  <div
    class="container-1200 flex flex-col items-center justify-center gap-6 text-center"
    style="padding-top:64px; padding-bottom:64px; min-height:200px;"
  >
    <!-- 필름 엣지 마크 -->
    <div class="flex items-center gap-3">
      <span style="width:24px;height:1px;background:var(--color-accent);opacity:.5;"></span>
      <span style="width:4px;height:4px;background:var(--color-accent);opacity:.4;transform:rotate(45deg);"></span>
      <span style="width:24px;height:1px;background:var(--color-accent);opacity:.5;"></span>
    </div>

    <p class="font-serif text-ink" style="font-size:14px;letter-spacing:0.15em;text-transform:uppercase;">
      {site.brandFull}
    </p>

    <p class="text-muted" style="font-size:12px;font-weight:300;letter-spacing:0.1em;">
      {site.copyright}
    </p>

    <a
      href="https://www.velnoc.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-muted transition-colors duration-300"
      style="font-size:11px;opacity:.7;"
    >
      Made with VELNOC
    </a>
  </div>
</footer>
