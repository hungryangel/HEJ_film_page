---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — HEJ Film" description="페이지를 찾을 수 없습니다.">
  <section class="container-1200 text-center" style="padding-top:200px;padding-bottom:200px;">
    <h1 class="font-serif italic text-ink" style="font-size:clamp(48px,8vw,72px);font-weight:300;">404</h1>
    <p class="text-muted" style="margin-top:16px;">찾으시는 페이지가 없습니다.</p>
    <a
      href="/"
      class="mt-10 inline-block font-sans transition-all duration-300 hover:bg-ink hover:text-bg"
      style="font-size:14px;color:var(--color-ink);border:1px solid var(--color-ink);padding:16px 40px;"
    >
      홈으로 돌아가기
    </a>
  </section>
</BaseLayout>
