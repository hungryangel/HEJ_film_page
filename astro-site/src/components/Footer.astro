---
/**
 * Footer — 인스타 핸들 + 카피라이트 + 제작 크레딧 (절제된 미니멀)
 *  · 배경에 옅은 "HEJ" 세리프 워터마크
 *  · 스크롤이 닿으면 콘텐츠가 페이드인 (.reveal — ui.ts의 IntersectionObserver 연동)
 */
import { site } from '../data/site';
import { contactLinks } from '../data/site';
---

<footer class="footer-dark w-full" style="background:var(--color-dark);">
  <!-- 배경 워터마크 (장식, 스크린리더 무시) -->
  <span class="footer-watermark font-serif" aria-hidden="true">{site.brand}</span>

  <div
    class="reveal container-1200 flex flex-col items-center justify-center text-center"
    style="padding-top:72px; padding-bottom:72px; gap:14px; position:relative; z-index:1;"
  >
    <!-- 인스타 핸들 — 바로 연락처로 -->
    <a
      href={contactLinks.instagram}
      target="_blank"
      rel="noopener noreferrer"
      class="footer-handle font-serif"
      aria-label={`인스타그램 ${contactLinks.instagramHandle}`}
    >
      {contactLinks.instagramHandle}
    </a>

    <p class="footer-copy" style="color:var(--color-on-dark-muted);">
      {site.copyright}
    </p>

    <a
      href="https://www.velnoc.com"
      target="_blank"
      rel="noopener noreferrer"
      class="footer-credit"
    >
      Made with VELNOC
    </a>
  </div>
</footer>

<style>
  /* 상단에 골드 헤어라인을 가운데로 갈수록 옅어지게 — 절제된 고급감 */
  .footer-dark {
    position: relative;
    overflow: hidden;
    border-top: 1px solid transparent;
    border-image: linear-gradient(
        to right,
        transparent,
        rgba(196, 168, 130, 0.35),
        transparent
      )
      1;
  }

  /* 배경 워터마크: 거의 안 보일 정도(약 3%)의 큰 세리프 "HEJ" */
  .footer-watermark {
    position: absolute;
    left: 50%;
    bottom: -0.28em;
    transform: translateX(-50%);
    font-size: clamp(140px, 26vw, 300px);
    line-height: 1;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: #ffffff;
    opacity: 0.03;
    pointer-events: none;
    white-space: nowrap;
    user-select: none;
  }

  /* 인스타 핸들 */
  .footer-handle {
    font-size: 15px;
    letter-spacing: 0.08em;
    color: var(--color-on-dark);
    transition: color 0.3s;
  }

  .footer-copy {
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.16em;
  }

  .footer-credit {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-on-dark-muted);
    opacity: 0.55;
    transition: opacity 0.3s, color 0.3s;
  }

  @media (hover: hover) {
    .footer-handle:hover {
      color: var(--color-accent);
    }
    .footer-credit:hover {
      opacity: 1;
      color: var(--color-accent);
    }
  }
</style>
