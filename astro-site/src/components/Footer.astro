---
/**
 * Footer — 필름 엣지 마크 + 브랜드 + 카피라이트
 */
import { site } from '../data/site';
---

<footer class="w-full" style="background:var(--color-dark); border-top:1px solid rgba(196,168,130,0.2);">
  <div
    class="container-1200 flex flex-col items-center justify-center gap-6 text-center"
    style="padding-top:64px; padding-bottom:64px; min-height:200px;"
  >
    <!-- 필름 엣지 마크 -->
    <div class="flex items-center gap-3">
      <span style="width:24px;height:1px;background:var(--color-accent);opacity:.7;"></span>
      <span style="width:4px;height:4px;background:var(--color-accent);opacity:.6;transform:rotate(45deg);"></span>
      <span style="width:24px;height:1px;background:var(--color-accent);opacity:.7;"></span>
    </div>

    <p class="font-serif" style="font-size:14px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-on-dark);">
      {site.brandFull}
    </p>

    <p style="font-size:12px;font-weight:300;letter-spacing:0.1em;color:var(--color-on-dark-muted);">
      {site.copyright}
    </p>

    <a
      href="https://www.velnoc.com"
      target="_blank"
      rel="noopener noreferrer"
      class="transition-opacity duration-300 hover:opacity-100"
      style="font-size:11px;opacity:.6;color:var(--color-on-dark-muted);"
    >
      Made with VELNOC
    </a>
  </div>
</footer>
