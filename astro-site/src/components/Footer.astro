---
/**
 * Footer
 *  · 필기체 영문 태그라인(브랜드 정체성)
 *  · 인스타 핸들 + 카피라이트 + 제작 크레딧
 *  · 데스크톱: 좌(시그니처) / 우(메타) 한 줄 배치 · 모바일: 중앙 세로 정렬
 *  · 스크롤이 닿으면 페이드인 (.reveal — ui.ts IntersectionObserver 연동)
 */
import { site, contactLinks } from '../data/site';
---

<footer class="footer-dark w-full" style="background:var(--color-dark);">
  <div class="reveal footer-inner container-1200">
    <!-- 왼쪽: 필기체 시그니처 -->
    <p class="footer-signature font-script" aria-hidden="true">
      {site.signature}
    </p>

    <!-- 오른쪽: 핸들 · 카피라이트 · 크레딧 -->
    <div class="footer-meta">
      <a
        href={contactLinks.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-handle font-serif"
        aria-label={`인스타그램 ${contactLinks.instagramHandle}`}
      >
        {contactLinks.instagramHandle}
      </a>
      <span class="footer-divider" aria-hidden="true"></span>
      <p class="footer-copy">{site.copyright}</p>
      <a
        href="https://www.velnoc.com"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-credit"
      >
        Made with VELNOC
      </a>
    </div>
  </div>
</footer>

<style>
  /* 상단 골드 헤어라인 (가운데로 갈수록 옅어짐) */
  .footer-dark {
    border-top: 1px solid transparent;
    border-image: linear-gradient(
        to right,
        transparent,
        rgba(196, 168, 130, 0.35),
        transparent
      )
      1;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 18px;
    padding-top: 64px;
    padding-bottom: 64px;
  }

  /* 필기체 시그니처 */
  .footer-signature {
    font-size: clamp(26px, 3.4vw, 34px);
    line-height: 1.2;
    color: var(--color-accent);
    /* 살짝 밝게 — 다크 배경에서 골드가 충분히 떠 보이도록 */
    opacity: 0.92;
  }

  /* 오른쪽 메타 묶음 */
  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .footer-handle {
    font-size: 15px;
    letter-spacing: 0.08em;
    color: var(--color-on-dark);
    transition: color 0.3s;
  }
  /* 데스크톱 한 줄 배치에서만 보이는 점 구분자 */
  .footer-divider {
    display: none;
  }
  .footer-copy {
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.16em;
    color: var(--color-on-dark-muted);
  }
  .footer-credit {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-on-dark-muted);
    opacity: 0.55;
    transition: opacity 0.3s, color 0.3s;
  }

  @media (hover: hover) {
    .footer-handle:hover {
      color: var(--color-accent);
    }
    .footer-credit:hover {
      opacity: 1;
      color: var(--color-accent);
    }
  }

  /* ── 데스크톱: 좌(시그니처) / 우(메타) 한 줄 배치 ── */
  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
      gap: 24px;
    }
    .footer-meta {
      flex-direction: row;
      align-items: center;
      gap: 18px;
    }
    /* 메타 항목 사이 골드 점 구분자 */
    .footer-divider {
      display: inline-block;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--color-accent);
      opacity: 0.5;
    }
  }
</style>
